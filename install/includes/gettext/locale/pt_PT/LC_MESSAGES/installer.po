msgstr "Bom a saber:"

#: install/index.php:434
msgid ""
"Use your callsign as your username for QRZ.com. The XML API does not support "
"email addresses."
msgstr ""
"Utilize o seu indicativo como nome de utilizador para o QRZ.com. A API XML "
"não suporta endereços de email."

#: install/index.php:442
msgid "API Token"
msgstr "Token de API"

#: install/index.php:452
msgid "Generate a Personal Access Token at"
msgstr "Gerar um Token de Acesso Pessoal em"

#: install/index.php:454

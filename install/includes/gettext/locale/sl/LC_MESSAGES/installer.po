#: install/index.php:1193
msgid "Back"
msgstr "Nazaj"

#: install/index.php:1194
msgid "Continue"
msgstr "Nadaljuj"

#: install/index.php:1272
msgid ""
"You can't continue. Solve the red marked issues, restart the webserver and "
"reload this page."
msgstr ""
"Ne morete nadaljevati. Rešite rdeče označene težave, znova zaženite spletni "
"strežnik in ponovno naložite to stran."

#: install/index.php:1399
msgid "Password can't contain ' / \\ < >"
msgstr "Geslo ne sme vsebovati ' / \\ < >"

#: install/index.php:1403
msgid ""
"The callsign should not contain any pre- or suffixes as it is used as "
"personal operator callsign."
msgstr ""
"Klicni znak ne sme vsebovati pre- ali sufixov, saj se uporablja kot osebni "
"klicni znak operaterja."

#: install/index.php:1415
msgid ""
"The callsign can not contain any special characters. It's your personal "
"callsign without any pre- or suffixes."
msgstr ""
"Klicni znak ne sme vsebovati posebnih znakov. To je vaš osebni klicni znak "
"brez pre- ali sufiksov."

#: install/index.php:1576
msgid "Error: At least Hostname/IP, Database Name and Username are required."
msgstr ""
"Napaka: Zahtevani so vsaj podatki o imenu gostitelja/IP-ju, imenu baze "
"podatkov in uporabniškem imenu."

#: install/index.php:1586
msgid "Connecting..."
msgstr "Povezovanje ..."

#: install/index.php:1610
msgid "Connection was successful and your database should be compatible."
msgstr ""
"Povezava je bila uspešna in vaša baza podatkov bi morala biti združljiva."

#: install/index.php:1614
msgid ""
"Connection was successful but your database seems too old for Wavelog. You "
"can try to continue but you could run into issues."
msgstr ""
"Povezava je bila uspešna, vendar se zdi, da je vaša baza podatkov prestara "
"za Wavelog. Lahko poskusite nadaljevati, vendar lahko naletite na težave."

#: install/index.php:1614
#, php-format
msgid "The min. version for MySQL is %s, for MariaDB it's %s."
msgstr "Minimalna različica za MySQL je %s, za MariaDB pa %s."

#: install/index.php:1734
msgid "Search"
msgstr "Išči"

#: install/index.php:1771
msgid "At least one field is empty."
msgstr "Vsaj eno polje je prazno."

#: install/index.php:1790
msgid ""
"Stop here for a Moment. Your chosen DXCC is outdated and not valid anymore. "
"Check which DXCC for this particular location is the correct one. If you are "
"sure, ignore this warning."
msgstr ""
"Za trenutek se ustavite. Vaša izbrana DXCC je zastarela in ni več veljavna. "
"Preverite, katera DXCC za to lokacijo je pravilna. Če ste prepričani, "
"prezrite to opozorilo."

#: install/index.php:1814
msgid ""
"The locator seems to be not in the correct format. Should look like AA11AA "
"(6-char grid locator)."
msgstr ""
"Zdi se, da lokator ni v pravilni obliki. Izgledati bi moral kot AA11AA (6-"
"mestni UL lokator)."

#: install/index.php:1828
msgid ""
"The e-mail adress does not look correct. Make sure it's a valid e-mail "
"address"
msgstr "E-poštni naslov ni videti pravilen. Prepričajte se, da je veljaven"

#: install/index.php:1855
msgid "Password should be at least 8 characters long"
msgstr "Geslo mora biti dolgo vsaj 8 znakov"

#: install/index.php:1864
msgid "Passwords do not match"
msgstr "Gesli se ne ujemata"

#: install/index.php:1920
msgid "Install Now"
msgstr "Namesti zdaj"

#: install/index.php:1924
msgid "Install not possible. Checklist incomplete."
msgstr "Namestitev ni mogoča. Kontrolni seznam ni popoln."

#: install/index.php:2036
msgid "PHP Module missing"
msgstr "PHP Modul manjka"

#: install/index.php:2038
msgid "The following PHP modules are missing:"
msgstr "Manjkajo naslednji PHP moduli:"

#: install/index.php:2039
msgid "Without this module the Wavelog Installer does not work!"
msgstr "Brez tega modula namestitveni program Wavelog ne deluje!"

#: install/index.php:2040
msgid "Please install the required modules and restart the webserver."
msgstr "Namestite potrebne module in ponovno zaženite spletni strežnik."

#: install/run.php:22
msgid "Installation"
msgstr "Namestitev"

#: install/run.php:24
msgid "Please wait..."
msgstr "Prosim, počakajte..."

#: install/run.php:27
msgid "Copy config.php to application/config/"
msgstr "Skopirajte config.php v application/config/"


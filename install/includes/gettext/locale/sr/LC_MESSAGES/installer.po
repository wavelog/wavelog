#: install/index.php:1137
msgid "Reset"
msgstr "Reset"

#: install/index.php:1142
msgid "Installer Reset"
msgstr "Reset instalacije"

#: install/index.php:1145
msgid "Do you really want to reset all data and start from scratch?"

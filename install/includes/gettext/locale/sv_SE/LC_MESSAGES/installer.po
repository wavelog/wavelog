msgstr "Skapar databastabeller"

#: install/run.php:36
msgid "Running database migrations"
msgstr "Utför databas-migreringar"

#: install/run.php:39
msgid "Updating DXCC data"
msgstr "Uppdaterar DXCC-data"

#: install/run.php:47
msgid "Lock the installer"
msgstr "Låser installationen"

